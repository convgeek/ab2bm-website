# Sanity
# Source: sanity.io/manage > Project Settings > API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Source: sanity.io/manage > Project Settings > API > Tokens > Create Viewer token
SANITY_API_READ_TOKEN=

# Supabase
# Source: Supabase dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Source: Supabase dashboard > Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Tag Manager
# Source: tagmanager.google.com > Your container ID (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# HubSpot (required for Plan 01-05 — conversion layer)
# Source: HubSpot account settings > Private Apps > Create private app token
HUBSPOT_PORTAL_ID=
# Source: HubSpot > Marketing > Forms > Inquiry form > Settings > Sharing > Embed code
HUBSPOT_INQUIRY_FORM_GUID=
# Source: HubSpot > Marketing > Forms > Media Kit form > Settings > Sharing > Embed code
HUBSPOT_MEDIAKIT_FORM_GUID=
# Source: HubSpot account settings > Private Apps > your app token
HUBSPOT_PRIVATE_APP_TOKEN=
# Set to "true" in development to skip HubSpot API calls
DEV_MOCK_HUBSPOT=true
